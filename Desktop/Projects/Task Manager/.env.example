# AssemblyAI — for speech-to-text transcription (assemblyai.com → API Keys)
ASSEMBLYAI_API_KEY=...

# Groq — for MOM + task generation with Llama 3.3 (console.groq.com → API Keys)
GROQ_API_KEY=gsk_...

# Gmail — use an App Password (myaccount.google.com → Security → App Passwords)
EMAIL_USER=you@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

PORT=3001

# Secret for /api/admin/stats endpoint — set any strong password
ADMIN_SECRET=your_admin_password_here

# Your Vercel frontend URL (set this in Railway environment variables)
FRONTEND_URL=https://your-app.vercel.app
